# MiniAgent 环境变量配置示例
# 复制此文件为 .env 并修改值

# 权限模式: auto (自动允许) | ask (询问用户) | strict (严格模式，拒绝所有)
MINI_AGENT_PERMISSION=ask

# 使用的模型名称 (例如: deepseek-reasoner, gpt-4, claude-3-opus)
MINI_AGENT_MODEL=deepseek-reasoner

# 最大对话轮数 (一轮 = user + assistant)
MINI_AGENT_MAX_TURNS=20

# 触发压缩的消息数阈值
MINI_AGENT_COMPACTION_THRESHOLD=40

# 其他可选环境变量
API_KEY=your_api_key_here